## test1.lang - All Valid Tokens
## Demonstrates every token type recognized by the scanner

## Keywords (all 12)
start
    declare Count = 0
    declare Flag = true

    loop condition Count < 10
        Count++
        condition Count == 5
            break
        else
            continue
        finish
    finish

    function Add(Param1, Param2):
        return Param1 + Param2
    finish

    input Name
    output "Done"
finish

## Identifiers
declare Simple = 1
declare With_underscore = 2
declare Variable with spaces = 3

## Integer literals
declare Pos = 42
declare Neg = -7
declare Zero = 0

## Float literals
declare Pi = 3.14
declare Small = 0.000001
declare Sci1 = 1.5e10
declare Sci2 = 2.0E-3

## String literal
declare Greeting = "Hello World"

## Character literal
declare Letter = 'A'

## Boolean literals
declare Yes = true
declare No = false

## Arithmetic operators: + - * / % **
declare Sum = 10 + 20 - 5 * 2 / 1 % 3
declare Power = 2 ** 8

## Relational operators: == != < > <= >=
condition Sum == 25
finish
condition Sum != 0
finish
condition Sum < 100
finish
condition Sum > 0
finish
condition Sum <= 50
finish
condition Sum >= 10
finish

## Logical operators: && || !
condition Sum > 0 && Flag
finish
condition Sum > 100 || Flag
finish
condition !Flag
finish

## Assignment operators: = += -= *= /=
Sum = 0
Sum += 10
Sum -= 2
Sum *= 3
Sum /= 4

## Increment/Decrement: ++ --
Sum++
Sum--

## Punctuators: ( ) { } [ ] , ; :
declare Arr[10]
declare Mat[5][5]
output {Sum; Pi}

## Single-line comment
## Multi-line comment
#* This is a
   multi-line comment *#
